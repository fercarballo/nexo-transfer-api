# Plantilla de variables de entorno de nexo-transfer-api.
# Copiar a .env y completar. NUNCA subir el .env con valores reales al repositorio.

# Puerto HTTP de la API (opcional; por defecto 8080).
PORT=8080

# Tokens de autenticación (token -> usuario).
# En LOCAL, application.yml ya trae valores de desarrollo (tok-ana-local-dev, tok-luis-local-dev)
# que NO son secretos y sirven solo para correr y testear la app.
# En un entorno real, estos valores se inyectan por variables de entorno y se sobreescriben
# los del yaml. Ejemplo de override por env (Spring relaxed binding):
#
#   NEXO_SECURITY_TOKENS_<TOKEN>=<userId>
#
# No incluir tokens productivos en este archivo ni en el control de versiones.
